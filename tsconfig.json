// 我的mac耗电量很大，我怀疑是这个的问题
{
  "compilerOptions": {
    "incremental": true,        // 开启增量编译，省电核心
    "skipLibCheck": true,       // 跳过库检查
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,             // 只做检查，不写文件（减少磁盘IO）
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src"]            // 缩小扫描范围
}